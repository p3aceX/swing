<?xml version="1.0" encoding="utf-8"?>
<!-- Brand plate (logo/sponsor) background: semi-opaque navy plate with a
     2px mustard top hairline. Same plate visual as Flutter LogoMark. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E60F1B2D" />
        </shape>
    </item>
    <item android:top="0dp">
        <shape android:shape="rectangle">
            <size android:height="2dp" />
            <solid android:color="#E6B544" />
        </shape>
    </item>
</layer-list>
