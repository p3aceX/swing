DATABASE_URL=postgresql://postgres:password@localhost:5432/swing
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx
AWS_S3_BUCKET=swing-media
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=ap-south-1
CLOUDFRONT_URL=https://cdn.swing.cricket
# Firebase (used for Phone Auth verification + FCM push)
# Paste the full JSON of your Firebase service account key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8081

# Local development defaults:
# - npm run dev starts API + workers together
# - npm run start:api starts only the API unless START_WORKERS=true
# - npm run start:worker starts only BullMQ workers with a small /health server
START_WORKERS=true

# Docker / Cloud Run only:
# SERVICE_MODE=api    -> API service
# SERVICE_MODE=worker -> dedicated worker service
# SERVICE_MODE=all    -> single container running API + workers
SERVICE_MODE=api
