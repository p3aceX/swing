  sourceRefId     String?
  notes           String?
  createdAt       DateTime @default(now())

  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, date])
  @@map("player_workload_events")
}

model PlayerJournalStreakDay {
  id                 String   @id @default(cuid())
  playerId           String
  date               DateTime @db.Date
  hasWorkload        Boolean  @default(false)
  hasWellness        Boolean  @default(false)
  isActive           Boolean  @default(false)
  streakCount        Int      @default(0)
  activeDaysInWindow Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, date])
  @@index([playerId, date])
  @@map("player_journal_streak_days")
}

model EliteInsight {
  id        String   @id @default(cuid())
  playerId  String
  category  String // TACTICAL | PHYSICAL | MENTAL
  title     String
  message   String
  priority  Int      @default(1) // 1 (Low) to 3 (High)
  isRead    Boolean  @default(false)
  matchId   String? // Optional: The match that triggered this insight
  createdAt DateTime @default(now())

  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
  @@map("elite_insights")
}

model PlayerLeadershipSample {
  id                      String   @id @default(cuid())
  playerId                String
  matchId                 String
  wasCaptain              Boolean  @default(false)
  teamWin                 Boolean  @default(false)
  closeMatch              Boolean  @default(false)
  chaseMatch              Boolean  @default(false)
  captaincyInfluenceScore Float?
  createdAt               DateTime @default(now())

  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match  Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([playerId, createdAt])
  @@map("player_leadership_samples")
}

// ============================================================
