  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([playerId, matchDate])
  @@map("match_player_facts")
}

model MatchPlayerMetric {
  id                        String   @id @default(cuid())
  matchId                   String
  playerId                  String
  strikeRate                Float?
  boundaryRatePerBall       Float?
  boundaryRunsPct           Float?
  scoringContributionPct    Float?
  dismissalStabilityMetric  Float?
  pressureBattingMetric     Float?
  economyRate               Float?
  ballsPerWicket            Float?
  dotBallPct                Float?
  wicketContributionPct     Float?
  spellQualityMetric        Float?
  phaseDifficultyMetric     Float?
  fieldingInvolvementMetric Float?
  physicalWorkloadMetric    Float?
  captaincyInfluenceMetric  Float?
  createdAt                 DateTime @default(now())

  match  Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([playerId, createdAt])
  @@map("match_player_metrics")
}

model MatchPlayerIndexScore {
  id                      String   @id @default(cuid())
  matchId                 String
  playerId                String
  battingIndex            Float?
  bowlingIndex            Float?
  fieldingIndex           Float?
  consistencyContribution Float?
  clutchIndex             Float?
  physicalIndex           Float?
  captaincyIndex          Float?
  gameInfluenceIndex      Float?
  performanceScore        Float
  impactPoints            Int
  seasonPoints            Int
  passMultiplierApplied   Float    @default(1)
  isMvp                   Boolean  @default(false)
  createdAt               DateTime @default(now())

  match  Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([playerId, createdAt])
  @@index([matchId, impactPoints])
  @@map("match_player_index_scores")
}

model PlayerIndexAggregate {
