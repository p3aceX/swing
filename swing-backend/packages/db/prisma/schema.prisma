  targetDate  DateTime?
  isCompleted Boolean   @default(false)
  completedAt DateTime?

  plan TrainingPlan @relation(fields: [planId], references: [id])
}

model CoachFeedback {
  id                String   @id @default(cuid())
  playerProfileId   String
  coachId           String
  sessionId         String?
  feedbackText      String?
  voiceNoteUrl      String?
  videoClipUrl      String?
  videoTimestamp    Int?
  tags              String[]
  isVisibleToParent Boolean  @default(true)
  createdAt         DateTime @default(now())

  playerProfile PlayerProfile    @relation(fields: [playerProfileId], references: [id])
  coach         CoachProfile     @relation(fields: [coachId], references: [id])
  session       PracticeSession? @relation(fields: [sessionId], references: [id])

  @@index([playerProfileId, createdAt])
}

model ReportCard {
  id              String    @id @default(cuid())
  playerProfileId String
  coachId         String
  periodMonth     Int
  periodYear      Int
  swingIndexStart Float
  swingIndexEnd   Float
  attendanceRate  Float
  drillCompletion Float
  coachNarrative  String?
  strengthsNote   String?
  focusAreasNote  String?
  goalsNextMonth  String?
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  parentViewedAt  DateTime?
  createdAt       DateTime  @default(now())

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id])
  coach         CoachProfile  @relation(fields: [coachId], references: [id])

  @@unique([playerProfileId, periodMonth, periodYear])
}

// ============================================================
// SECTION 10 — TOURNAMENTS
// ============================================================

model Tournament {
  id                String           @id @default(cuid())
  createdByUserId   String?
  academyId         String?
  name              String
  description       String?
  format            MatchFormat
  sport             Sport            @default(CRICKET)
  startDate         DateTime
  endDate           DateTime?
  venueName         String?
  city              String?
  maxTeams          Int              @default(8)
  entryFee          Int?
  prizePool         String?
  rules             String?
  logoUrl           String?
  coverUrl          String?
  slug              String?          @unique
  highlights        Json?
  isPublic          Boolean          @default(true)
  isVerified        Boolean          @default(false)
  status            String           @default("UPCOMING")
  tournamentFormat  TournamentFormat @default(LEAGUE)
  seriesMatchCount  Int?
  groupCount        Int              @default(1)
  pointsForWin      Int              @default(2)
  pointsForLoss     Int              @default(0)
  pointsForTie      Int              @default(1)
  pointsForNoResult Int              @default(1)
  ballType          String           @default("LEATHER")
  earlyBirdDeadline DateTime?
  earlyBirdFee      Int?
  organiserName     String?
  organiserPhone    String?
  livePin           String?
  overlayPackId     String?
  createdAt         DateTime         @default(now())

  createdBy   User?                @relation(fields: [createdByUserId], references: [id])
  academy     Academy?             @relation(fields: [academyId], references: [id])
  overlayPack OverlayPack?         @relation(fields: [overlayPackId], references: [id])
  teams       TournamentTeam[]
  groups      TournamentGroup[]
  standings   TournamentStanding[]

  @@index([overlayPackId])
  @@index([createdByUserId])
}

model TournamentTeam {
  id           String   @id @default(cuid())
  tournamentId String
  teamId       String?
  teamName     String
  captainId    String?
  playerIds    String[]
  isConfirmed  Boolean  @default(false)
  groupId      String?
  seed         Int?
  registeredAt DateTime @default(now())

  tournament Tournament          @relation(fields: [tournamentId], references: [id])
  team       Team?               @relation(fields: [teamId], references: [id])
  group      TournamentGroup?    @relation(fields: [groupId], references: [id])
  standing   TournamentStanding?
}

model Team {
  id                  String    @id @default(cuid())
  name                String
  shortName           String?
  logoUrl             String?
  city                String?
  teamType            TeamType  @default(FRIENDLY)
  captainId           String?
  viceCaptainId       String?
  wicketKeeperId      String?
  playerIds           String[]  @default([])
  supportStaff        Json?
  powerScore          Float     @default(0) // weighted avg IP of players — used for matchmaking
  powerScoreUpdatedAt DateTime?
  createdByUserId     String
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tournamentTeams    TournamentTeam[]
  matchmakingLobbies MatchmakingLobby[]

  @@index([city])
  @@index([powerScore])
}

model TournamentGroup {
  id           String @id @default(cuid())
  tournamentId String
  name         String
  groupOrder   Int    @default(0)

  tournament Tournament           @relation(fields: [tournamentId], references: [id])
  teams      TournamentTeam[]
  standings  TournamentStanding[]

  @@unique([tournamentId, name])
}

model TournamentStanding {
  id               String  @id @default(cuid())
  tournamentId     String
  groupId          String?
  tournamentTeamId String  @unique
  position         Int     @default(0)
  played           Int     @default(0)
  won              Int     @default(0)
  lost             Int     @default(0)
  tied             Int     @default(0)
  noResult         Int     @default(0)
  points           Int     @default(0)
  runsScored       Int     @default(0)
  ballsFaced       Int     @default(0)
  runsConceded     Int     @default(0)
  ballsBowled      Int     @default(0)
  nrr              Float   @default(0)

  tournament Tournament       @relation(fields: [tournamentId], references: [id])
  group      TournamentGroup? @relation(fields: [groupId], references: [id])
  team       TournamentTeam   @relation(fields: [tournamentTeamId], references: [id])

  @@unique([tournamentId, tournamentTeamId])
  @@index([tournamentId, points])
}

// ============================================================
// SECTION 11 — ARENA
// ============================================================

model ArenaOwnerProfile {
  id           String  @id @default(cuid())
  userId       String  @unique
  businessName String?
  gstNumber    String?
  panNumber    String?

  user   User    @relation(fields: [userId], references: [id])
  arenas Arena[]
}

model ArenaManager {
  id        String   @id @default(cuid())
  arenaId   String
  userId    String
  name      String
  phone     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  arena Arena @relation(fields: [arenaId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([arenaId, userId])
  @@index([arenaId])
}

model Arena {
  id                 String    @id @default(cuid())
  ownerId            String
  businessAccountId  String?
  name               String
  description        String?
  photoUrls          String[]
  city               String
  state              String
  address            String
  pincode            String
  latitude           Float
  longitude          Float
  phone              String?
  sports             Sport[]
  hasParking         Boolean   @default(false)
  hasLights          Boolean   @default(false)
  hasWashrooms       Boolean   @default(false)
  hasCanteen         Boolean   @default(false)
  hasCCTV            Boolean   @default(false)
  hasScorer          Boolean   @default(false)
  openTime           String    @default("06:00")
  closeTime          String    @default("22:00")
  operatingDays      Int[]     @default([1, 2, 3, 4, 5, 6, 7])
  advanceBookingDays Int       @default(7)
  bufferMins         Int       @default(15)
  cancellationHours  Int       @default(24)
  planTier           PlanTier  @default(FREE)
  planExpiresAt      DateTime?
  isVerified         Boolean   @default(false)
  isSwingArena       Boolean   @default(false)
  arenaGrade         String?
  verifiedAt         DateTime?
  rating             Float     @default(0)
  totalRatings       Int       @default(0)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  owner           ArenaOwnerProfile @relation(fields: [ownerId], references: [id])
  businessAccount BusinessAccount?  @relation(fields: [businessAccountId], references: [id], onDelete: SetNull)
  units           ArenaUnit[]
  addons          ArenaAddon[]
  bookings           SlotBooking[]
  timeBlocks         ArenaTimeBlock[]
  reviews            Review[]
  managers           ArenaManager[]
  monthlyPasses      MonthlyPass[]
  matchmakingLobbies MatchmakingLobby[]

  citySlug     String?
  arenaSlug    String?
  customSlug   String?
  isPublicPage Boolean @default(true)

  @@unique([citySlug, arenaSlug])
  @@unique([customSlug])
  @@index([businessAccountId])
  @@index([city, isVerified])
  @@index([latitude, longitude])
}

model ArenaUnit {
  id                   String           @id @default(cuid())
  arenaId              String
  name                 String
  unitType             FacilityUnitType
  unitTypeLabel        String?
  netType              String?
  netVariants          Json?
  sport                Sport            @default(CRICKET)
  capacity             Int              @default(22)
  description          String?
  photoUrls            String[]
  pricePerHourPaise    Int
  peakPricePaise       Int?
  peakHoursStart       String?
  peakHoursEnd         String?
  price4HrPaise        Int?
  price8HrPaise        Int?
  priceFullDayPaise    Int?
  boundarySize         Int?
  weekendMultiplier    Float            @default(1.0)
  minSlotMins          Int              @default(60)
  maxSlotMins          Int              @default(240)
  slotIncrementMins    Int              @default(60)
  turnaroundMins       Int              @default(0)
  minAdvancePaise      Int              @default(0)
  openTime             String?
  closeTime            String?
  operatingDays        Int[]            @default([])
  hasFloodlights       Boolean          @default(false)
  parentUnitId         String?
  advanceBookingDays   Int?
  bufferMins           Int?
  cancellationHours    Int?
  minBulkDays          Int?
  bulkDayRatePaise     Int?
  monthlyPassEnabled   Boolean          @default(false)
  monthlyPassRatePaise Int?
  isActive             Boolean          @default(true)
  createdAt            DateTime         @default(now())

  arena         Arena            @relation(fields: [arenaId], references: [id])
  parentUnit    ArenaUnit?       @relation("UnitHierarchy", fields: [parentUnitId], references: [id], onDelete: SetNull)
  childUnits    ArenaUnit[]      @relation("UnitHierarchy")
  addons        ArenaAddon[]
  bookings      SlotBooking[]
  timeBlocks    ArenaTimeBlock[]
  pricingRules  PricingRule[]
  monthlyPasses MonthlyPass[]
  lobbyPicks    MatchmakingLobbyPick[]
  matchmakingMatches MatchmakingMatch[]
}

model PricingRule {
  id          String  @id @default(cuid())
  unitId      String
  name        String
  discountPct Int     @default(0)
  premiumPct  Int     @default(0)
  appliesTo   String  @default("ALL")
  dayOfWeek   Int?
  startTime   String?
  endTime     String?
  isActive    Boolean @default(true)

  unit ArenaUnit @relation(fields: [unitId], references: [id])
}

model ArenaTimeBlock {
  id          String    @id @default(cuid())
  arenaId     String
  unitId      String
  date        DateTime? @db.Date
  startTime   String
  endTime     String
  reason      String?
  isRecurring Boolean   @default(false)
  isHoliday   Boolean   @default(false)
  weekdays    Int[]     @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  arena Arena     @relation(fields: [arenaId], references: [id])
  unit  ArenaUnit @relation(fields: [unitId], references: [id])

  @@index([arenaId, unitId, date])
  @@index([arenaId, unitId, isRecurring])
}

model ArenaAddon {
  id          String  @id @default(cuid())
  arenaId     String
  unitId      String?
  name        String
  addonType   String?
  description String?
  pricePaise  Int
  unit        String  @default("per_session")
  isAvailable Boolean @default(true)

  arena         Arena              @relation(fields: [arenaId], references: [id])
  arenaUnit     ArenaUnit?         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  bookingAddons SlotBookingAddon[]

  @@index([arenaId, unitId])
}

model SlotBooking {
  id                   String       @id @default(cuid())
  arenaId              String
  unitId               String
  arenaUnitId          String?
  bookedById           String
  playerProfileId      String?
  bookingDate          DateTime?    @db.Date
  date                 DateTime     @db.Date
  startTime            String
  endTime              String
  durationMins         Int
  sport                Sport        @default(CRICKET)
  format               MatchFormat?
  teamSize             Int          @default(11)
  baseAmountPaise      Int          @default(0)
  addonAmountPaise     Int          @default(0)
  discountPaise        Int          @default(0)
  totalAmountPaise     Int
  totalPricePaise      Int          @default(0)
  status               SlotStatus   @default(HELD)
  heldUntil            DateTime?
  checkInQrCode        String?      @unique
  checkedInAt          DateTime?
  paidAt               DateTime?
  matchId              String?
  matchmakingId        String?
  academyId            String?
  notes                String?
  cancellationReason   String?
  cancelledAt          DateTime?
  // Offline / walk-in booking fields
  isOfflineBooking     Boolean      @default(false)
  createdByOwnerId     String?
  guestName            String?
  guestPhone           String?
  guestUserId          String?
  guestPlayerProfileId String?
  guestSource          String?
  paymentMode          String? // ONLINE | CASH | UPI | CARD | BANK_TRANSFER
  advancePaise         Int          @default(0)
  endDate              DateTime?    @db.Date
  isBulkBooking        Boolean      @default(false)
  bulkDayRatePaise     Int?
  bookingSource        String       @default("APP")
  monthlyPassId        String?
  netVariantType       String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  arena              Arena              @relation(fields: [arenaId], references: [id])
  unit               ArenaUnit          @relation(fields: [unitId], references: [id])
  bookedBy           PlayerProfile      @relation("SlotBookingBookedBy", fields: [bookedById], references: [id])
  guestUser          User?              @relation("SlotBookingGuestUser", fields: [guestUserId], references: [id])
  guestPlayerProfile PlayerProfile?     @relation("SlotBookingGuestPlayer", fields: [guestPlayerProfileId], references: [id])
  addons             SlotBookingAddon[]
  payment            Payment?
  monthlyPass        MonthlyPass?       @relation(fields: [monthlyPassId], references: [id])

  @@index([arenaId, date, status])
  @@index([unitId, date])
  @@index([monthlyPassId])
  @@index([guestUserId])
  @@index([guestPlayerProfileId])
}

model SlotBookingAddon {
  id         String @id @default(cuid())
  bookingId  String
  addonId    String
  quantity   Int    @default(1)
  pricePaise Int

  booking SlotBooking @relation(fields: [bookingId], references: [id])
  addon   ArenaAddon  @relation(fields: [addonId], references: [id])
}

model MonthlyPass {
  id               String   @id @default(cuid())
  arenaId          String
  unitId           String
  guestName        String
  guestPhone       String
  startTime        String
  endTime          String
  daysOfWeek       Int[]
  startDate        DateTime @db.Date
  endDate          DateTime @db.Date
  totalAmountPaise Int
  advancePaise     Int      @default(0)
  paymentMode      String   @default("CASH")
  notes            String?
  status           String   @default("ACTIVE")
  bookingSource    String   @default("BIZ")
  createdAt        DateTime @default(now())

  arena    Arena         @relation(fields: [arenaId], references: [id])
  unit     ArenaUnit     @relation(fields: [unitId], references: [id])
  sessions SlotBooking[]

  @@index([arenaId])
  @@index([unitId])
}

// ============================================================
// SECTION 12 — MATCHMAKING
// ============================================================

model MatchmakingQueue {
  id              String      @id @default(cuid())
  playerProfileId String
  sport           Sport       @default(CRICKET)
  format          MatchFormat @default(T20)
  teamSize        Int         @default(11)
  isTeamCaptain   Boolean     @default(true)
  preformedTeam   String[]
  preferredDate   DateTime?
  availableFrom   DateTime
  availableUntil  DateTime
  maxDistanceKm   Int         @default(10)
  latitude        Float?
  longitude       Float?
  ipAtQueue       Float       @default(0) // player's rankProgressPoints at time of queuing
  teamPowerScore  Float? // set when queuing as a team captain
  status          QueueStatus @default(WAITING)
  matchedWith     String?
  matchId         String?
  bookingId       String?
  expiresAt       DateTime
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id])

  @@index([sport, format, status])
  @@index([ipAtQueue, status])
}

model MatchmakingRequest {
  id                          String      @id @default(cuid())
  playerProfileId             String
  opponentPlayerProfileId     String?
  initiatorQueueId            String?
  opponentQueueId             String?
  format                      MatchFormat
  matchType                   MatchType
  preferredDate               DateTime?
  preferredVenueName          String?
  proposedArenaId             String?
  proposedDateTime            DateTime?
  costPerPlayerPaise          Int?
  latitude                    Float?
  longitude                   Float?
  radiusKm                    Int         @default(25)
  ipAtRequest                 Float       @default(0)
  notes                       String?
  confirmedByPlayerProfileIds String[]    @default([])
  status                      String      @default("OPEN")
  matchedAt                   DateTime?
  expiresAt                   DateTime
  createdAt                   DateTime    @default(now())

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id])

  @@index([format, matchType, status])
  @@index([ipAtRequest, status])
}

model MatchmakingLobby {
  id             String   @id @default(cuid())
  teamId         String?
  playerId       String?
  arenaId        String?
  splitBookingId String?  @unique
  format         String
  ballType       String?
  date           DateTime @db.Date
  status         String   @default("searching")
  matchId        String?
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  team   Team?                @relation(fields: [teamId], references: [id])
  player PlayerProfile?       @relation(fields: [playerId], references: [id])
  arena  Arena?               @relation(fields: [arenaId], references: [id])
  picks  MatchmakingLobbyPick[]

  @@index([status, date, format])
  @@index([teamId, status])
  @@index([matchId])
  @@index([arenaId, status])
}

model MatchmakingLobbyPick {
  id              String @id @default(cuid())
  lobbyId         String
  groundId        String
  slotTime        String
  preferenceOrder Int    @default(1)

  lobby  MatchmakingLobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  ground ArenaUnit        @relation(fields: [groundId], references: [id])

  @@index([groundId, slotTime])
  @@index([lobbyId, preferenceOrder])
}

model MatchmakingMatch {
  id                   String   @id @default(cuid())
  lobbyAId             String   @unique
  lobbyBId             String   @unique
  groundId             String
  slotTime             String
  date                 DateTime @db.Date
  format               String
  status               String   @default("pending_confirm")
  confirmDeadline      DateTime
  teamAConfirmed       Boolean  @default(false)
  teamBConfirmed       Boolean  @default(false)
  paymentAmountPerTeam Int
  bookingId            String?
  createdAt            DateTime @default(now())

  ground ArenaUnit @relation(fields: [groundId], references: [id])

  @@index([status, confirmDeadline])
  @@index([date, format, groundId, slotTime])
}

// ============================================================
// SECTION 13 — GAMIFICATION
// ============================================================

model Badge {
  id          String   @id @default(cuid())
  key         String?  @unique
  name        String   @unique
  description String
  iconUrl     String?
  category    String
  ipBonus     Int      @default(0)
  isRare      Boolean  @default(false)
  triggerRule String?
  createdAt   DateTime @default(now())

  playerBadges PlayerBadge[]
}

model PlayerBadge {
  id              String   @id @default(cuid())
  playerProfileId String
  badgeId         String
  awardedAt       DateTime @default(now())
  awardedReason   String?
  matchId         String?
  isDisplayed     Boolean  @default(true)

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id])
  badge         Badge         @relation(fields: [badgeId], references: [id])

  @@unique([playerProfileId, badgeId])
}

model PlayerMilestone {
  id              String   @id @default(cuid())
  playerProfileId String
  title           String
  description     String?
  achievedAt      DateTime @default(now())
  ipAwarded       Int      @default(0)
  matchId         String?
  badgeId         String?

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id])
}

model IpTransaction {
  id              String   @id @default(cuid())
  playerProfileId String
  ipDelta         Int // positive = earned, negative = lost
  reason          String // e.g. "BATTING_PERFORMANCE", "WIN_BONUS", "LOSS_PENALTY", "RANK_DECAY"
  matchId         String?
  referenceId     String?
  rankBefore      String? // CompetitiveRankKey:division snapshot
  rankAfter       String?
  createdAt       DateTime @default(now())

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id])

  @@index([playerProfileId, createdAt])
}

// ============================================================
// SECTION 14 — GIG MARKETPLACE
// ============================================================

model GigListing {
  id                   String         @id @default(cuid())
  coachId              String
  title                String
  description          String?
  gigType              String         @default("CUSTOM")
  sessionType          GigSessionType @default(IN_PERSON)
  sport                Sport          @default(CRICKET)
  skillFocus           String[]
  durationMins         Int            @default(60)
  pricePaise           Int            @default(0)
  pricePerSessionPaise Int            @default(0)
  platformFeePaise     Int            @default(0)
  coachPayoutPaise     Int            @default(0)
  maxStudents          Int            @default(1)
  availableDays        Int[]
  availableFrom        String         @default("06:00")
  availableUntil       String         @default("22:00")
  availableDates       DateTime[]
  targetBattingStyle   String[]
  targetBowlingStyle   String[]
  targetAgeMin         Int?
  targetAgeMax         Int?
  isOnline             Boolean        @default(false)
  locationName         String?
  city                 String?
  latitude             Float?
  longitude            Float?
  targetLevels         PlayerLevel[]
  tags                 String[]
  advanceBookingDays   Int            @default(7)
  minNoticeHours       Int            @default(4)
  cancellationHours    Int            @default(24)
  isActive             Boolean        @default(true)
  isFeatured           Boolean        @default(false)
  totalBookings        Int            @default(0)
  rating               Float          @default(0)
  totalRatings         Int            @default(0)
  createdAt            DateTime       @default(now())

  coach    CoachProfile @relation(fields: [coachId], references: [id])
  bookings GigBooking[]
  packages GigPackage[]
  slots    GigSlot[]

  @@index([city, sport])
}

model GigPackage {
  id              String   @id @default(cuid())
  gigListingId    String
  name            String
  description     String?
  sessionCount    Int
  validityDays    Int      @default(90)
  totalPricePaise Int
  perSessionPaise Int
  savingsPaise    Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  gigListing GigListing @relation(fields: [gigListingId], references: [id])
}

model GigSlot {
  id           String         @id @default(cuid())
  coachId      String
  gigListingId String?
  isTemplate   Boolean        @default(false)
  dayOfWeek    Int?
  slotDate     DateTime?      @db.Date
  startTime    String
  endTime      String
  durationMins Int
  sessionType  GigSessionType @default(IN_PERSON)
  locationName String?
  isAvailable  Boolean        @default(true)
  isBlocked    Boolean        @default(false)
  blockReason  String?
  bookingId    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  gigListing GigListing? @relation(fields: [gigListingId], references: [id])

  @@index([coachId, slotDate, isAvailable])
}

model GigBooking {
  id                   String           @id @default(cuid())
  gigListingId         String
  coachId              String
  playerProfileId      String
  slotId               String?
  packageId            String?
  packageSessionNumber Int?
  sessionType          GigSessionType
  scheduledAt          DateTime
  durationMins         Int
  locationName         String?
  meetingLink          String?
  amountPaise          Int
  platformFeePaise     Int              @default(0)
  coachPayoutPaise     Int              @default(0)
  paymentId            String?
  status               GigBookingStatus @default(PENDING_PAYMENT)
  bookingReference     String?          @unique
  playerGoals          String?
  coachPreNotes        String?
  coachPostNotes       String?
  sessionVideoUrl      String?
  paidAt               DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  cancellationReason   String?
  refundEligible       Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  gigListing    GigListing    @relation(fields: [gigListingId], references: [id])
  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id])
  payment       Payment?

  @@index([playerProfileId, scheduledAt])
  @@index([coachId, scheduledAt])
}

// ============================================================
// SECTION 15 — PAYMENTS
// ============================================================

model Payment {
  id                String        @id @default(cuid())
  userId            String
  amountPaise       Int
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  gateway           String        @default("RAZORPAY")
  gatewayOrderId    String?       @unique
  gatewayPaymentId  String?       @unique
  gatewaySignature  String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  entityType  String?
  entityId    String?
  description String?

  slotBookingId  String? @unique
  gigBookingId   String? @unique
  subscriptionId String?
  feePaymentId   String?

  splitGroupId String?
  splitPart    Int?

  method            String?
  failureReason     String?
  completedAt       DateTime?
  refundedAt        DateTime?
  refundReason      String?
  refundAmountPaise Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  slotBooking SlotBooking? @relation(fields: [slotBookingId], references: [id])
  gigBooking  GigBooking?  @relation(fields: [gigBookingId], references: [id])

  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

model Subscription {
  id            String    @id @default(cuid())
  userId        String
  entityId      String
  entityType    String
  planTier      PlanTier
  status        String    @default("ACTIVE")
  startedAt     DateTime  @default(now())
  expiresAt     DateTime
  razorpaySubId String?
  autoRenew     Boolean   @default(true)
  cancelledAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([entityId, entityType, status])
}

// ============================================================
// SECTION 16 — NOTIFICATIONS
// ============================================================

model Notification {
  id          String              @id @default(cuid())
  userId      String
  type        String              @default("SYSTEM")
  channel     NotificationChannel @default(PUSH)
  status      NotificationStatus  @default(QUEUED)
  title       String?
  body        String
  data        Json?
  entityType  String?
  entityId    String?
  isRead      Boolean             @default(false)
  toPhone     String?
  provider    String?
  providerId  String?
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  failedAt    DateTime?
  failReason  String?
  createdAt   DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, isRead])
}

model NotificationPreference {
  userId               String   @id
  pushEnabled          Boolean  @default(true)
  chatMessages         Boolean  @default(true)
  newFollowers         Boolean  @default(true)
  rankUpdates          Boolean  @default(true)
  matchResults         Boolean  @default(true)
  productAnnouncements Boolean  @default(true)
  arenaBookings        Boolean  @default(true)
  bookingReminders     Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ============================================================
// SECTION 17 — REVIEWS
// ============================================================

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  arenaId    String?
  coachId    String?
  gigId      String?
  rating     Int
  comment    String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  reviewer User   @relation(fields: [reviewerId], references: [id])
  arena    Arena? @relation(fields: [arenaId], references: [id])
}

// ============================================================
// SECTION 18 — INVENTORY
// ============================================================

model InventoryItem {
  id          String        @id @default(cuid())
  academyId   String
  name        String
  category    String
  quantity    Int           @default(1)
  condition   ItemCondition @default(GOOD)
  purchasedAt DateTime?
  cost        Int?
  notes       String?
  isAssigned  Boolean       @default(false)
  assignedTo  String?
  assignedAt  DateTime?

  academy Academy @relation(fields: [academyId], references: [id])
}

// ============================================================
// SECTION 19 — ANNOUNCEMENTS
// ============================================================

model Announcement {
  id          String   @id @default(cuid())
  academyId   String
  authorId    String
  title       String
  body        String
  targetGroup String   @default("ALL")
  isPinned    Boolean  @default(false)
  sentVia     String[] @default(["PUSH"])
  createdAt   DateTime @default(now())

  academy Academy @relation(fields: [academyId], references: [id])
}

