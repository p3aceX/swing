  targetUnit   DrillTargetUnit @default(REPS)
  isActive     Boolean         @default(true)
  isPublic     Boolean         @default(false)
  usageCount   Int             @default(0)
  createdAt    DateTime        @default(now())

  createdBy   CoachProfile?     @relation(fields: [createdById], references: [id])
  assignments DrillAssignment[]
  planItems   DrillPlanItem[]

  @@index([skillArea, difficulty])
}

model DrillPlan {
  id          String   @id @default(cuid())
  name        String
  description String?
  coachId     String
  createdAt   DateTime @default(now())

  items    DrillPlanItem[]
  sessions PracticeSession[]
}

model DrillPlanItem {
  id      String  @id @default(cuid())
  planId  String
  drillId String
  order   Int
  reps    Int?
  sets    Int?
  notes   String?

  plan  DrillPlan @relation(fields: [planId], references: [id])
  drill Drill     @relation(fields: [drillId], references: [id])
}

model DrillAssignment {
  id                 String           @id @default(cuid())
  sessionId          String?
  drillId            String
  playerProfileId    String
  assignedById       String
  coachId            String?
  targetQuantity     Int?
