// ============================================================
// SECTION 2 — USERS & AUTH
// ============================================================

model User {
  id            String     @id @default(cuid())
  phone         String     @unique
  email         String?    @unique
  name          String
  avatarUrl     String?
  roles         UserRole[]
  activeRole    UserRole   @default(PLAYER)
  isVerified    Boolean    @default(false)
  isActive      Boolean    @default(true)
  isBanned      Boolean    @default(false)
  banReason     String?
  isBlocked     Boolean    @default(false)
  blockedReason String?
  language      String     @default("en")
  deviceTokens  String[]
  fcmTokens     String[]
  sourceLabels  String[]   @default([])
  createdVia    String?
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  playerProfile          PlayerProfile?
  coachProfile           CoachProfile?
  academyOwnerProfile    AcademyOwnerProfile?
  arenaOwnerProfile      ArenaOwnerProfile?
  arenaManagerProfiles   ArenaManager[]
  parentProfile          ParentProfile?
  otpVerifications       OtpVerification[]
  notifications          Notification[]
  payments               Payment[]
  supportTickets         SupportTicket[]
  reviews                Review[]
  hostedTournaments      Tournament[]
  hostedEvents           Event[]
  refreshTokens          RefreshToken[]
  notificationPreference NotificationPreference?
  businessAccount        BusinessAccount?
  arenaGuestBookings     SlotBooking[]           @relation("SlotBookingGuestUser")

  storeOwnerProfile      StoreOwnerProfile?
  deliveryPartnerProfile DeliveryPartnerProfile?
  storeOrders            StoreOrder[]
  deliveryJobs           DeliveryJob[]

  @@index([phone])
}

model BusinessAccount {
  id                 String   @id @default(cuid())
  userId             String   @unique
  businessName       String
  contactName        String?
  phone              String?
  email              String?
  city               String?
  state              String?
  address            String?
  pincode            String?
  latitude           Float?
  longitude          Float?
  gstNumber          String?
  panNumber          String?
  beneficiaryName    String?
  accountNumber      String?
  ifscCode           String?
  upiId              String?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  coachProfile CoachProfile?
  academies    Academy[]
  arenas       Arena[]
  stores       Store[]

  @@index([city])
  @@map("business_accounts")
}

model OtpVerification {
  id        String    @id @default(cuid())
  userId    String
  phone     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([phone, code])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ============================================================
// SECTION 3 — PLAYER PROFILE
// ============================================================

model PlayerProfile {
  id                   String       @id @default(cuid())
  userId               String       @unique
  username             String?      @unique // public @handle — shown in app as the player's Swing ID
  dateOfBirth          DateTime?
  gender               String?
  heightCm             Float?
  weightKg             Float?
  waistCircumferenceCm Float?
  neckCircumferenceCm  Float?
  hipCircumferenceCm   Float?
  city                 String?
  state                String?
  playerRole           PlayerRole   @default(BATSMAN)
  battingStyle         BattingStyle @default(RIGHT_HAND)
  bowlingStyle         BowlingStyle @default(NOT_A_BOWLER)
  level                PlayerLevel  @default(CLUB)
  goals                String?
  jerseyNumber         Int?
  bio                  String?
  availableDays        String[]
  preferredTimes       String[]
  locationRadius       Int          @default(10)
  isPublic             Boolean      @default(true)
  showStats            Boolean      @default(true)
  showLocation         Boolean      @default(false)
  scoutingOptIn        Boolean      @default(false)

  followersCount Int @default(0) // denormalised — updated on follow / unfollow
  followingCount Int @default(0)

  swingIndex       Float @default(0)
  battingScore     Float @default(0)
  bowlingScore     Float @default(0)
  fieldingScore    Float @default(0)
  fitnessScore     Float @default(0)
  gameIntelligence Float @default(0)
  coachability     Float @default(0)

  matchesPlayed Int @default(0)
  matchesWon    Int @default(0)
  noShowCount   Int @default(0)

  totalRuns       Int   @default(0)
  totalBallsFaced Int   @default(0)
  highestScore    Int   @default(0)
  fifties         Int   @default(0)
  hundreds        Int   @default(0)
  fours           Int   @default(0)
  sixes           Int   @default(0)
  battingAverage  Float @default(0)
  strikeRate      Float @default(0)

  totalWickets      Int     @default(0)
  totalOversBowled  Float   @default(0)
  bestBowling       String?
  fiveWicketHauls   Int     @default(0)
  bowlingAverage    Float   @default(0)
  economyRate       Float   @default(0)
  bowlingStrikeRate Float   @default(0)

  catches   Int @default(0)
  stumpings Int @default(0)
  runOuts   Int @default(0)

  verificationLevel VerificationLevel @default(UNVERIFIED)
  verifiedAt        DateTime?
  verifiedById      String?

  // Academy registration fields
  bloodGroup            String?
  aadhaarLast4          String?
  emergencyContactName  String?
  emergencyContactPhone String?

  hasActiveInjury Boolean  @default(false)
  injuryNote      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  playerMatchStats         PlayerMatchStats[]
  battingEvents            BallEvent[]                   @relation("BatterEvents")
  bowlingEvents            BallEvent[]                   @relation("BowlerEvents")
  sessionAttendances       SessionAttendance[]
  drillAssignments         DrillAssignment[]
  drillProgressLogs        DrillProgressLog[]
  trainingPlans            TrainingPlan[]
  metricSnapshots          MetricSnapshot[]
  reportCards              ReportCard[]
  feedbackTimeline         CoachFeedback[]
  sessionSignals           PlayerSessionSignal[]
  playerGoal               PlayerGoal?
  queueEntries             MatchmakingQueue[]
  matchmakingRequests      MatchmakingRequest[]
  matchmakingLobbies       MatchmakingLobby[]
  playerBadges             PlayerBadge[]
  playerMilestones         PlayerMilestone[]
  academyEnrollments       AcademyEnrollment[]
  slotBookings             SlotBooking[]                 @relation("SlotBookingBookedBy")
  guestSlotBookings        SlotBooking[]                 @relation("SlotBookingGuestPlayer")
  gigBookings              GigBooking[]
  studentSessionLogs       StudentSessionLog[]
  ipTransactions           IpTransaction[]
  skillMatrixSnapshot      SkillMatrixSnapshot[]
  oneOnOneBookings         OneOnOneBooking[]
  competitiveProfile       PlayerCompetitiveProfile?
  seasonProgress           PlayerSeasonProgress[]
  matchFacts               MatchPlayerFact[]
  matchMetrics             MatchPlayerMetric[]
  matchIndexScores         MatchPlayerIndexScore[]
  indexAggregate           PlayerIndexAggregate?
  indexSnapshots           PlayerIndexSnapshot[]
  physicalSamples          PlayerPhysicalSample[]
  leadershipSamples        PlayerLeadershipSample[]
  wellnessCheckins         PlayerWellnessCheckin[]
  workloadEvents           PlayerWorkloadEvent[]
  journalStreakDays        PlayerJournalStreakDay[]
  followers                PlayerFollow[]                @relation("PlayerFollowTarget")
  following                PlayerFollow[]                @relation("PlayerFollowSource")
  entityFollows            Follow[]
  eliteInsights            EliteInsight[]
  chatConversationsCreated ChatConversation[]            @relation("ChatConversationCreatedBy")
  chatParticipants         ChatConversationParticipant[] @relation("ChatConversationParticipantPlayer")
  chatMessagesSent         ChatMessage[]                 @relation("ChatMessageSender")
  showcaseItems            ProfileShowcaseItem[]
  performanceDayLogs       PerformanceDayLog[]
  performanceWeeklyReviews PerformanceWeeklyReview[]
  performanceAmbition      PerformanceAmbition?
  weeklyPlanTemplates      WeeklyPlanTemplate[]
  performancePlan          PerformancePlan?

  @@index([city, level])
}

model MetricSnapshot {
  id                 String             @id @default(cuid())
  playerProfileId    String
  date               DateTime           @db.Date
  swingIndex         Float
  battingScore       Float
  bowlingScore       Float
  fieldingScore      Float
  fitnessScore       Float
  rankKey            CompetitiveRankKey
  rankDivision       Int
  rankProgressPoints Int

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id])

  @@unique([playerProfileId, date])
  @@index([playerProfileId, date])
}

// ============================================================
// SECTION 4A — COMPETITIVE / DIAGNOSTIC PROGRESSION
// ============================================================

model CompetitiveSeason {
  id        String   @id @default(cuid())
  name      String
  startAt   DateTime
  endAt     DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  currentPlayers PlayerCompetitiveProfile[]
  progress       PlayerSeasonProgress[]

  @@index([isActive, startAt, endAt])
  @@map("competitive_seasons")
}

model PlayerCompetitiveProfile {
  playerId             String             @id
  playerName           String? // denormalised display name for leaderboards / ranked lists
  lifetimeImpactPoints Int                @default(0) // never decreases — career legacy
  currentRankKey       CompetitiveRankKey @default(ROOKIE)
  currentDivision      Int                @default(3)
  rankProgressPoints   Int                @default(0) // can go up AND down
  currentDivisionFloor Int                @default(0) // IP floor when this division was entered (for demotion calc)
  winStreak            Int                @default(0)
  mvpCount             Int                @default(0)
  lastRankedMatchAt    DateTime? // for inactivity decay
  hasPremiumPass       Boolean            @default(false)
  premiumPassExpiresAt DateTime?
  currentSeasonId      String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  player        PlayerProfile      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  currentSeason CompetitiveSeason? @relation(fields: [currentSeasonId], references: [id], onDelete: SetNull)

  @@index([currentRankKey, currentDivision])
  @@index([currentSeasonId])
  @@map("player_competitive_profile")
}

model PlayerSeasonProgress {
  id                         String   @id @default(cuid())
  playerId                   String
  seasonId                   String
  seasonPoints               Int      @default(0)
  mvpCount                   Int      @default(0)
  matchesPlayed              Int      @default(0)
  currentLeaderboardPosition Int?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  player PlayerProfile     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  season CompetitiveSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([playerId, seasonId])
  @@index([seasonId, seasonPoints])
  @@map("player_season_progress")
}

model PlayerFollow {
  followerPlayerId  String
  followingPlayerId String
  createdAt         DateTime @default(now())

  follower  PlayerProfile @relation("PlayerFollowSource", fields: [followerPlayerId], references: [id], onDelete: Cascade)
  following PlayerProfile @relation("PlayerFollowTarget", fields: [followingPlayerId], references: [id], onDelete: Cascade)

  @@id([followerPlayerId, followingPlayerId])
  @@index([followingPlayerId, createdAt])
  @@index([followerPlayerId, createdAt])
  @@map("player_follows")
}

// General follow for teams and tournaments (player→entity)
model Follow {
  id         String           @id @default(cuid())
  followerId String // PlayerProfile.id
  targetId   String // Team.id or Tournament.id
  targetType FollowTargetType
  createdAt  DateTime         @default(now())

  follower PlayerProfile @relation(fields: [followerId], references: [id], onDelete: Cascade)

  @@unique([followerId, targetId, targetType])
  @@index([targetId, targetType, createdAt])
  @@index([followerId, createdAt])
  @@map("follows")
}

// ── View tracking ─────────────────────────────────────────────────────────────

model ProfileView {
  id        String   @id @default(cuid())
  profileId String // PlayerProfile.id being viewed
  viewerId  String? // PlayerProfile.id of viewer (null = anonymous)
  viewedAt  DateTime @default(now())

  @@index([profileId, viewedAt])
  @@index([viewerId, viewedAt])
  @@map("profile_views")
}

model MatchView {
  id       String   @id @default(cuid())
  matchId  String
  viewerId String? // PlayerProfile.id (null = anonymous)
  viewedAt DateTime @default(now())

  @@index([matchId, viewedAt])
  @@map("match_views")
}

model TournamentView {
  id           String   @id @default(cuid())
  tournamentId String
  viewerId     String? // PlayerProfile.id (null = anonymous)
  viewedAt     DateTime @default(now())

  @@index([tournamentId, viewedAt])
  @@map("tournament_views")
}

model ChatConversation {
  id                  String               @id @default(cuid())
  type                ChatConversationType @default(DIRECT)
  directKey           String?              @unique
  teamId              String?              @unique // for TEAM_CHAT — one chat per team
  title               String?
  avatarUrl           String?
  createdByPlayerId   String?
  lastMessageAt       DateTime?
  lastMessagePreview  String?
  lastMessageSenderId String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  createdBy    PlayerProfile?                @relation("ChatConversationCreatedBy", fields: [createdByPlayerId], references: [id], onDelete: SetNull)
  participants ChatConversationParticipant[]
  messages     ChatMessage[]

  @@index([lastMessageAt, updatedAt])
  @@map("chat_conversations")
}

model ChatConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  playerId       String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?
  mutedAt        DateTime?

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  player       PlayerProfile    @relation("ChatConversationParticipantPlayer", fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([conversationId, playerId])
  @@index([playerId, joinedAt])
  @@map("chat_conversation_participants")
}

model ChatMessage {
  id             String          @id @default(cuid())
  conversationId String
  senderPlayerId String
  kind           ChatMessageKind @default(TEXT)
  body           String
  attachmentUrl  String?
  createdAt      DateTime        @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       PlayerProfile    @relation("ChatMessageSender", fields: [senderPlayerId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderPlayerId, createdAt])
  @@map("chat_messages")
}

model ProfileShowcaseItem {
  id              String                  @id @default(cuid())
  playerProfileId String
  type            ProfileShowcaseItemType
  title           String?
  caption         String?
  url             String
  thumbnailUrl    String?
  matchId         String?
  isPinned        Boolean                 @default(false)
  isActive        Boolean                 @default(true)
  sortOrder       Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  match         Match?        @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([playerProfileId, isPinned, sortOrder, createdAt])
  @@index([playerProfileId, isActive, createdAt])
  @@map("profile_showcase_items")
}

// ============================================================
// SECTION 4 — COACH PROFILE
// ============================================================

model CoachProfile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  businessAccountId    String?   @unique
  bio                  String?
  specializations      String[]
  certifications       String[]
  experienceYears      Int       @default(0)
  city                 String?
  state                String?
  gigEnabled           Boolean   @default(false)
  hourlyRate           Int?
  rating               Float     @default(0)
  totalRatings         Int       @default(0)
  totalSessions        Int       @default(0)
  onTimeSessions       Int       @default(0)
  punctualityScore     Float     @default(100)
  isVerified           Boolean   @default(false)
  verifiedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  oneOnOneEnabled      Boolean   @default(false)
  publicProfileVisible Boolean   @default(true)

  user               User                  @relation(fields: [userId], references: [id])
  businessAccount    BusinessAccount?      @relation(fields: [businessAccountId], references: [id], onDelete: SetNull)
  academies          AcademyCoach[]
  sessions           PracticeSession[]
  sessionSchedules   SessionSchedule[]
  drillsCreated      Drill[]
  assignedDrills     DrillAssignment[]
  feedbackGiven      CoachFeedback[]
  gigListings        GigListing[]
  reportCards        ReportCard[]
  sessionLogs        SessionLog[]
  studentSessionLogs StudentSessionLog[]
  sessionSignals     PlayerSessionSignal[]
  compensation       CoachCompensation[]
  payoutRecords      CoachPayoutRecord[]
  oneOnOneProfile    OneOnOneProfile?
  oneOnOneBookings   OneOnOneBooking[]
}

// ============================================================
// SECTION 5 — ACADEMY / B2B
// ============================================================

model AcademyOwnerProfile {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id])
  academies Academy[]
}

model Academy {
  id                String    @id @default(cuid())
  ownerId           String
  businessAccountId String?
  name              String
  description       String?
  logoUrl           String?
  city              String
  state             String
  address           String?
  pincode           String?
  latitude          Float?
  longitude         Float?
  phone             String?
  email             String?
  websiteUrl        String?
  tagline           String?
  foundedYear       Int?
  planTier          PlanTier  @default(FREE)
  planExpiresAt     DateTime?
  maxStudents       Int       @default(50)
  isVerified        Boolean   @default(false)
  verifiedAt        DateTime?
  totalStudents     Int       @default(0)
  totalCoaches      Int       @default(0)
  totalBatches      Int       @default(0)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  owner                AcademyOwnerProfile   @relation(fields: [ownerId], references: [id])
  businessAccount      BusinessAccount?      @relation(fields: [businessAccountId], references: [id], onDelete: SetNull)
  coaches              AcademyCoach[]
  batches              Batch[]
  enrollments          AcademyEnrollment[]
  sessions             PracticeSession[]
  feeStructures        FeeStructure[]
  feePayments          FeePayment[]
  announcements        Announcement[]
  inventory            InventoryItem[]
  tournaments          Tournament[]
  sessionLogs          SessionLog[]
  curriculums          Curriculum[]
  coachCompensations   CoachCompensation[]
  coachPayoutRecords   CoachPayoutRecord[]
  skillMatrixSnapshots SkillMatrixSnapshot[]
  sessionSchedules     SessionSchedule[]
  sessionTypeConfigs   SessionTypeConfig[]
  skillAreas           SkillArea[]
  watchFlags           WatchFlag[]

  @@index([businessAccountId])
  @@index([city, isVerified])
}

model AcademyCoach {
  id          String   @id @default(cuid())
  academyId   String
  coachId     String
  isHeadCoach Boolean  @default(false)
  joinedAt    DateTime @default(now())
  isActive    Boolean  @default(true)

  academy Academy      @relation(fields: [academyId], references: [id])
  coach   CoachProfile @relation(fields: [coachId], references: [id])

  @@unique([academyId, coachId])
}

// Recurring session template — e.g. "Mon+Tue Pace Nets at 8am"
model SessionSchedule {
  id           String      @id @default(cuid())
  coachId      String
  academyId    String?
  batchId      String?
  sessionType  SessionType
  daysOfWeek   Int[] // 0=Sun 1=Mon … 6=Sat
  startTime    String // "HH:MM"
  durationMins Int         @default(90)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  coach    CoachProfile      @relation(fields: [coachId], references: [id])
  academy  Academy?          @relation(fields: [academyId], references: [id])
  batch    Batch?            @relation(fields: [batchId], references: [id])
  sessions PracticeSession[]
}

model Batch {
  id             String   @id @default(cuid())
  academyId      String
  name           String
  ageGroup       String?
  maxStudents    Int      @default(20)
  sport          Sport    @default(CRICKET)
  description    String?
  skillLevel     String? // Beginner | Intermediate | Advanced | Elite
  venueNote      String?
  primaryCoachId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  academy              Academy                    @relation(fields: [academyId], references: [id])
  enrollments          AcademyEnrollment[]
  sessions             PracticeSession[]
  schedules            BatchSchedule[]
  sessionSchedules     SessionSchedule[]
  sessionLogs          SessionLog[]
  curriculumAssignment BatchCurriculumAssignment?
}

model BatchSchedule {
  id         String  @id @default(cuid())
  batchId    String
  dayOfWeek  Int
  startTime  String
  endTime    String
  groundNote String?
  coachId    String?
  isActive   Boolean @default(true)

  batch Batch @relation(fields: [batchId], references: [id])
}

model AcademyEnrollment {
  id                   String    @id @default(cuid())
  academyId            String
  playerProfileId      String
  batchId              String?
  enrolledAt           DateTime  @default(now())
  isActive             Boolean   @default(true)
  isTrial              Boolean   @default(false)
  trialEndsAt          DateTime?
  feePaidPaise         Int?
  feeAmountPaise       Int?
  feeFrequency         String?
  feeStatus            String    @default("UNPAID")
  registrationNo       String?
  notes                String?
  enrollmentStatus     String    @default("ACTIVE") // ACTIVE | TRIAL | PAUSED | INACTIVE
  primaryCoachId       String?
  lastInsightDate      DateTime?
  coachEngagementScore Int       @default(0)
  oneOnOneFlagged      Boolean   @default(false)
  parentName           String?
  parentPhone          String?
  parentEmail          String?
  internalRemarks      String?

  academy            Academy             @relation(fields: [academyId], references: [id])
  playerProfile      PlayerProfile       @relation(fields: [playerProfileId], references: [id])
  batch              Batch?              @relation(fields: [batchId], references: [id])
  studentSessionLogs StudentSessionLog[]
  feePayments        FeePayment[]

  @@unique([academyId, playerProfileId])
}

model ParentProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  playerProfileId String
  relationship    String   @default("Parent")
  phone           String
  name            String
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ============================================================
// SECTION 6 — ATTENDANCE & QR
// ============================================================

model PracticeSession {
  id                  String                @id @default(cuid())
  academyId           String?
  batchId             String?
  coachId             String
  status              PracticeSessionStatus @default(LIVE)
  sessionType         SessionType
  sessionTypeConfigId String?
  scheduledAt         DateTime
  durationMins        Int                   @default(90)
  locationName        String?
  latitude            Float?
  longitude           Float?
  notes               String?
  drillPlanId         String?

  sessionQrCode String?   @unique
  qrGeneratedAt DateTime?
  qrExpiresAt   DateTime?
  qrClosedAt    DateTime?

  coachCheckedInAt DateTime?
  coachLatitude    Float?
  coachLongitude   Float?
  isCoachLate      Boolean   @default(false)

  isCompleted  Boolean  @default(false)
  isCancelled  Boolean  @default(false)
  cancelReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  academy           Academy?              @relation(fields: [academyId], references: [id])
  batch             Batch?                @relation(fields: [batchId], references: [id])
  coach             CoachProfile          @relation(fields: [coachId], references: [id])
  sessionTypeConfig SessionTypeConfig?    @relation(fields: [sessionTypeConfigId], references: [id])
  drillPlan         DrillPlan?            @relation(fields: [drillPlanId], references: [id])
  attendances       SessionAttendance[]
  feedbacks         CoachFeedback[]
  playerSignals     PlayerSessionSignal[]
  drillAssignments  DrillAssignment[]
  scheduleId        String?
  sessionLog        SessionLog?
  schedule          SessionSchedule?      @relation(fields: [scheduleId], references: [id])

  @@index([academyId, scheduledAt])
}

model SessionAttendance {
  id              String                @id @default(cuid())
  sessionId       String
  playerProfileId String
  status          AttendanceStatus      @default(ABSENT)
  scannedAt       DateTime?
  scanMethod      String?
  joinMethod      AttendanceJoinMethod?
  markedAt        DateTime?
  exitAt          DateTime?
  lateMinutes     Int                   @default(0)
  notes           String?

  session       PracticeSession @relation(fields: [sessionId], references: [id])
  playerProfile PlayerProfile   @relation(fields: [playerProfileId], references: [id])

  @@unique([sessionId, playerProfileId])
}

// ============================================================
// SECTION 7 — FEE MANAGEMENT
// ============================================================

model FeeStructure {
  id            String   @id @default(cuid())
  academyId     String
  batchId       String?
  name          String
  amountPaise   Int
  frequency     String
  dueDayOfMonth Int      @default(1)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  academy  Academy      @relation(fields: [academyId], references: [id])
  payments FeePayment[]
}

model FeePayment {
  id              String        @id @default(cuid())
  academyId       String
  playerProfileId String
  enrollmentId    String?
  feeStructureId  String?
  amountPaise     Int
  dueDate         DateTime
  paidAt          DateTime?
  status          PaymentStatus @default(PENDING)
  paymentMode     String? // CASH | UPI | CARD | BANK_TRANSFER | CHEQUE
  razorpayOrderId String?
  receiptUrl      String?
  notes           String?
  remindersSent   Int           @default(0)
  lastReminderAt  DateTime?
  createdAt       DateTime      @default(now())

  academy      Academy            @relation(fields: [academyId], references: [id])
  enrollment   AcademyEnrollment? @relation(fields: [enrollmentId], references: [id])
  feeStructure FeeStructure?      @relation(fields: [feeStructureId], references: [id])

  @@index([academyId, status])
}

// ============================================================
// SECTION 8 — MATCHES & SCORING
// ============================================================

model Match {
  id                  String            @id @default(cuid())
  matchType           MatchType
  format              MatchFormat
  status              MatchStatus       @default(SCHEDULED)
  teamAName           String
  teamBName           String
  teamAId             String?
  teamBId             String?
  teamAPlayerIds      String[]
  teamBPlayerIds      String[]
  teamACaptainId      String?
  teamBCaptainId      String?
  teamAViceCaptainId  String?
  teamBViceCaptainId  String?
  teamAWicketKeeperId String?
  teamBWicketKeeperId String?
  tossWonBy           String?
  tossDecision        String?
  scheduledAt         DateTime
  startedAt           DateTime?
  completedAt         DateTime?
  venueName           String?
  venueId             String?
  ballType            String?
  customOvers         Int?
  testDays            Int?
  oversPerDay         Int?
  currentDay          Int               @default(1)
  round               String?
  facilityId          String?
  slotBookingId       String?
  academyId           String?
  tournamentId        String?
  winnerId            String?
  winMargin           String?
  scorerId            String?
  overlayPackId       String?
  verificationLevel   VerificationLevel @default(UNVERIFIED)
  verifiedAt          DateTime?
  isRanked            Boolean           @default(false)
  hasImpactPlayer     Boolean           @default(false)
  matchmakingId       String?
  highlights          Json              @default("[]")
  youtubeUrl          String?
  liveCode            String?           @unique
  livePin             String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  innings                 Innings[]
  overlayPack             OverlayPack?             @relation(fields: [overlayPackId], references: [id])
  overlayStudio           OverlayStudio?
  playerMatchStats        PlayerMatchStats[]
  matchFacts              MatchPlayerFact[]
  matchMetrics            MatchPlayerMetric[]
  indexScores             MatchPlayerIndexScore[]
  leadershipSamples       PlayerLeadershipSample[]
  showcaseItems           ProfileShowcaseItem[]
  performanceMatchReviews PerformanceMatchReview[]
  venue                   Venue?                   @relation(fields: [venueId], references: [id])

  @@index([academyId, scheduledAt])
  @@index([overlayPackId])
  @@index([tournamentId])
  @@index([venueId])
}

model Innings {
  id            String  @id @default(cuid())
  matchId       String
  inningsNumber Int
  battingTeam   String
  totalRuns     Int     @default(0)
  totalWickets  Int     @default(0)
  totalOvers    Float   @default(0)
  extras        Int     @default(0)
  isDeclared    Boolean @default(false)
  isCompleted   Boolean @default(false)
  isSuperOver   Boolean @default(false)

  // Live scoring state — persisted so any device can resume
  currentStrikerId    String?
  currentNonStrikerId String?
  currentBowlerId     String?

  match      Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  ballEvents BallEvent[]

  @@unique([matchId, inningsNumber])
}

model OverlayStudio {
  id                     String   @id @default(cuid())
  matchId                String   @unique
  activeSceneId          String?
  adBreakEnabled         Boolean  @default(false)
  adBreakDurationSeconds Int      @default(30)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  match                  Match                        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  activeScene            OverlayScene?                @relation("ActiveStudioScene", fields: [activeSceneId], references: [id], onDelete: SetNull)
  scenes                 OverlayScene[]               @relation("StudioScenes")
  triggers               OverlayTrigger[]
  adSlots                AdSlot[]
  adQueue                StudioAdQueue[]
  scheduledSceneSwitches StudioScheduledSceneSwitch[]

  @@index([matchId])
}

model OverlayPack {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  kind        OverlayPackKind @default(CUSTOM)
  description String?
  isActive    Boolean         @default(true)
  isDefault   Boolean         @default(false)
  config      Json            @default("{}")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  matches     Match[]
  tournaments Tournament[]

  @@index([isDefault])
  @@index([kind])
}

model OverlayScene {
  id            String    @id @default(cuid())
  studioId      String
  name          String
  sceneType     SceneType
  templateId    String
  dataOverrides Json      @default("{}")
  isAutomatic   Boolean   @default(true)
  displayOrder  Int       @default(0)
  createdAt     DateTime  @default(now())

  studio                 OverlayStudio                @relation("StudioScenes", fields: [studioId], references: [id], onDelete: Cascade)
  activeInStudios        OverlayStudio[]              @relation("ActiveStudioScene")
  targetTriggers         OverlayTrigger[]             @relation("TriggerTargetScene")
  scheduledSceneSwitches StudioScheduledSceneSwitch[]

  @@index([studioId, displayOrder])
}

model OverlayTrigger {
  id            String           @id @default(cuid())
  studioId      String
  eventType     TriggerEventType
  targetSceneId String
  delaySeconds  Int              @default(0)
  isEnabled     Boolean          @default(true)

  studio      OverlayStudio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  targetScene OverlayScene  @relation("TriggerTargetScene", fields: [targetSceneId], references: [id], onDelete: Cascade)

  @@index([studioId, eventType])
}

model AdSlot {
  id              String     @id @default(cuid())
  studioId        String
  type            AdSlotType
  title           String
  mediaUrl        String?
  brandName       String?
  brandLogoUrl    String?
  durationSeconds Int
  displayOrder    Int        @default(0)

  studio     OverlayStudio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  queueItems StudioAdQueue[]

  @@index([studioId, displayOrder])
}

model StudioAdQueue {
  id           String   @id @default(cuid())
  studioId     String
  adSlotId     String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  studio OverlayStudio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  adSlot AdSlot        @relation(fields: [adSlotId], references: [id], onDelete: Cascade)

  @@unique([studioId, adSlotId])
  @@index([studioId, displayOrder])
}

model StudioScheduledSceneSwitch {
  id            String    @id @default(cuid())
  studioId      String
  targetSceneId String
  scheduledAt   DateTime
  executedAt    DateTime?
  createdAt     DateTime  @default(now())

  studio      OverlayStudio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  targetScene OverlayScene  @relation(fields: [targetSceneId], references: [id], onDelete: Cascade)

  @@index([scheduledAt, executedAt])
  @@index([studioId, scheduledAt])
}

model BallEvent {
  id                String         @id @default(cuid())
  inningsId         String
  overNumber        Int
  ballNumber        Int
  batterId          String
  nonBatterId       String?
  bowlerId          String
  fielderId         String?
  outcome           BallOutcome
  runs              Int            @default(0)
  extras            Int            @default(0)
  totalRuns         Int            @default(0)
  isWicket          Boolean        @default(false)
  isOverthrow       Boolean        @default(false)
  overthrowRuns     Int            @default(0)
  dismissalType     DismissalType?
  dismissedPlayerId String?
  tags              String[]
  wagonZone         String?
  shotType          String?
  ballLine          String?
  ballLength        String?
  scoreAfterBall    String?
  scoredAt          DateTime       @default(now())
  isOfflineEntry    Boolean        @default(false)

  innings Innings       @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  batter  PlayerProfile @relation("BatterEvents", fields: [batterId], references: [id])
  bowler  PlayerProfile @relation("BowlerEvents", fields: [bowlerId], references: [id])

  @@index([inningsId, overNumber, ballNumber])
  @@index([batterId])
  @@index([nonBatterId])
  @@index([bowlerId])
}

model PlayerMatchStats {
  id              String         @id @default(cuid())
  matchId         String
  playerProfileId String
  team            String
  runs            Int            @default(0)
  balls           Int            @default(0)
  fours           Int            @default(0)
  sixes           Int            @default(0)
  strikeRate      Float          @default(0)
  isOut           Boolean        @default(false)
  dismissalType   DismissalType?
  battingPosition Int?
  oversBowled     Float          @default(0)
  wickets         Int            @default(0)
  runsConceded    Int            @default(0)
  wides           Int            @default(0)
  noBalls         Int            @default(0)
  economy         Float          @default(0)
  catches         Int            @default(0)
  stumpings       Int            @default(0)
  runOuts         Int            @default(0)
  isManOfMatch    Boolean        @default(false)
  // ipAwarded       Int            @default(0)
  // rankXpAwarded   Int            @default(0)

  match         Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerProfileId])
}

model MatchPlayerFact {
  id               String            @id @default(cuid())
  matchId          String
  playerId         String
  teamId           String
  opponentTeamId   String
  inningsNo        Int?
  battingPosition  Int?
  didBat           Boolean           @default(false)
  runs             Int               @default(0)
  ballsFaced       Int               @default(0)
  fours            Int               @default(0)
  sixes            Int               @default(0)
  dismissalType    DismissalType?
  wasNotOut        Boolean           @default(false)
  didBowl          Boolean           @default(false)
  ballsBowled      Int               @default(0)
  oversBowled      Float?
  maidens          Int               @default(0)
  wickets          Int               @default(0)
  runsConceded     Int               @default(0)
  dotBalls         Int               @default(0)
  wides            Int               @default(0)
  noBalls          Int               @default(0)
  catches          Int               @default(0)
  runOuts          Int               @default(0)
  stumpings        Int               @default(0)
  fieldTimeSeconds Int?
  oversFielded     Float?
  isCaptain        Boolean           @default(false)
  result           CompetitiveResult
  matchFormat      MatchFormat?
  ballType         String?
  matchDate        DateTime
  createdAt        DateTime          @default(now())

