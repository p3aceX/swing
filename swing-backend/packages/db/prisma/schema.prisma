  focus                Int?     @default(5)
  resilience           Int?     @default(5)
  // Apex Elite Physical Context
  hydrationLiters      Float?   @default(0)
  caloriesConsumed     Int?
  waistCircumferenceCm Float?
  neckCircumferenceCm  Float?
  hipCircumferenceCm   Float?
  bodyFatPercent       Float?
  notes                String?
  createdAt            DateTime @default(now())

  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, date])
  @@map("player_wellness_checkins")
}

model PlayerWorkloadEvent {
  id              String   @id @default(cuid())
  playerId        String
  type            String
  date            DateTime
  durationMinutes Int
  intensity       Int?
  oversBowled     Float?
  ballsBowled     Int?
  battingMinutes  Int?
  ballsFaced      Int?
  spellCount      Int?
  // Apex Elite: Link to technical drills
  drillIds        String[] @default([])
  isCheatDay      Boolean  @default(false)
