}

model SessionTypeConfig {
  id                     String   @id @default(cuid())
  academyId              String?
  name                   String   @unique
  color                  String
  defaultDurationMinutes Int      @default(90)
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  academy  Academy?          @relation(fields: [academyId], references: [id])
  sessions PracticeSession[]
}

model SkillArea {
  id        String   @id @default(cuid())
  academyId String?
  name      String
  roleTag   RoleTag
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy? @relation(fields: [academyId], references: [id])
}

model WatchFlag {
  id          String        @id @default(cuid())
  academyId   String?
  name        String
  roleTag     RoleTag
  severity    WatchSeverity @default(MONITOR)
  description String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  academy Academy? @relation(fields: [academyId], references: [id])
}

model PlayerSessionSignal {
  id               String         @id @default(cuid())
  sessionId        String
  playerProfileId  String
  coachId          String
  overallSignal    SignalOverall?
  strengthSkillIds String[]
  workOnSkillIds   String[]
  watchFlagIds     String[]
  followUpInDays   Int?
  coachNote        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  session       PracticeSession @relation(fields: [sessionId], references: [id])
  playerProfile PlayerProfile   @relation(fields: [playerProfileId], references: [id])
  coach         CoachProfile    @relation(fields: [coachId], references: [id])

  @@unique([sessionId, playerProfileId])
  @@index([playerProfileId, createdAt])
}

model DrillProgressLog {
  id                String   @id @default(cuid())
  drillAssignmentId String
  playerProfileId   String
  loggedAt          DateTime @default(now())
  quantityDone      Int

  drillAssignment DrillAssignment @relation(fields: [drillAssignmentId], references: [id])
  playerProfile   PlayerProfile   @relation(fields: [playerProfileId], references: [id])

  @@index([drillAssignmentId, loggedAt])
}

model PlayerGoal {
  id              String   @id @default(cuid())
  playerProfileId String   @unique
  goalText        String
  progressPercent Int      @default(0)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id])
}

model TrainingPlan {
  id              String    @id @default(cuid())
  playerProfileId String
  coachId         String?
  title           String
  description     String?
  startDate       DateTime
  endDate         DateTime?
  goals           String[]
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  playerProfile PlayerProfile   @relation(fields: [playerProfileId], references: [id])
  milestones    PlanMilestone[]
}

model PlanMilestone {
  id          String    @id @default(cuid())
  planId      String
