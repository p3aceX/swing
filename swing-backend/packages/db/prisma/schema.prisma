// SECTION 20 — ADMIN & PLATFORM
// ============================================================

model SupportTicket {
  id          String       @id @default(cuid())
  userId      String
  category    String
  subject     String
  description String
  status      TicketStatus @default(OPEN)
  priority    String       @default("NORMAL")
  assignedTo  String?
  resolvedAt  DateTime?
  resolution  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  messages TicketMessage[]
}

model TicketMessage {
  id            String   @id @default(cuid())
  ticketId      String
  authorId      String
  isFromSupport Boolean  @default(false)
  message       String
  attachmentUrl String?
  createdAt     DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id])
}

model PlatformConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorRole  UserRole
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

model Venue {
  id        String   @id @default(cuid())
  name      String
  aliases   String[]
  city      String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matches Match[]

  @@index([name])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("SWING_ADMIN")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================================
// SECTION 21 — SESSION LOGS & DEVELOPMENT TRACKING
// ============================================================

enum CompensationType {
  FIXED_MONTHLY
  PER_SESSION
  PER_BATCH
  FIXED_PLUS_INCENTIVE
  REVENUE_SHARE
}

enum PayoutStatus {
  PENDING
  PROCESSED
  PAID
}

// Coach logs one SessionLog per practice session
// Each SessionLog has one StudentSessionLog per student present
model SessionLog {
  id          String   @id @default(cuid())
  academyId   String
  batchId     String?
  coachId     String // CoachProfile.id
  sessionId   String?  @unique // links to PracticeSession if exists
  sessionDate DateTime
  sessionType String   @default("BATCH_PRACTICE")
  overallNote String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  academy     Academy             @relation(fields: [academyId], references: [id])
  batch       Batch?              @relation(fields: [batchId], references: [id])
  coach       CoachProfile        @relation(fields: [coachId], references: [id])
  session     PracticeSession?    @relation(fields: [sessionId], references: [id])
  studentLogs StudentSessionLog[]

  @@index([academyId, sessionDate])
  @@index([coachId, sessionDate])
  @@index([batchId, sessionDate])
}

model StudentSessionLog {
  id              String   @id @default(cuid())
  sessionLogId    String
  enrollmentId    String // AcademyEnrollment.id
  playerProfileId String // PlayerProfile.id (for future player app)
  coachId         String // CoachProfile.id (for easy lookup)
  academyId       String // for scoping
  batchId         String?
  sessionDate     DateTime

  strengthChips       String[] @default([])
  weaknessChips       String[] @default([])
  currentFocusArea    String?
  effortRating        Int? // 1-5
  coachNote           String?
  drillRecommended    String?
  followUpNeeded      Boolean  @default(false)
  oneOnOneRecommended Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionLog    SessionLog        @relation(fields: [sessionLogId], references: [id], onDelete: Cascade)
  enrollment    AcademyEnrollment @relation(fields: [enrollmentId], references: [id])
  playerProfile PlayerProfile     @relation(fields: [playerProfileId], references: [id])
  coach         CoachProfile      @relation(fields: [coachId], references: [id])

  @@unique([sessionLogId, enrollmentId])
  @@index([playerProfileId, sessionDate])
  @@index([enrollmentId, sessionDate])
  @@index([academyId, sessionDate])
}

// Computed skill matrix — regenerated on demand, stored as JSON
model SkillMatrixSnapshot {
  id              String   @id @default(cuid())
  playerProfileId String
  academyId       String
  computedAt      DateTime @default(now())
  dataPoints      Int      @default(0)
  // JSON shape: { [dimensionKey]: { score: number, trend: "IMPROVING"|"STABLE"|"DECLINING", count: number, lastUpdated: string } }
  dimensions      Json     @default("{}")

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id])
  academy       Academy       @relation(fields: [academyId], references: [id])

  @@unique([playerProfileId, academyId])
}

// ============================================================
// SECTION 22 — CURRICULUM
// ============================================================

model Curriculum {
  id               String   @id @default(cuid())
  academyId        String? // null = Swing platform template
  name             String
  targetAgeGroup   String? // e.g. "U-14", "U-19", "Senior"
  targetSkillLevel String? // Beginner | Intermediate | Advanced | Elite
  sportFocus       String? // BATTING | BOWLING | ALL_ROUND | FITNESS
  description      String?
  totalWeeks       Int?
  isActive         Boolean  @default(true)
  isTemplate       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  academy          Academy?                    @relation(fields: [academyId], references: [id])
  phases           CurriculumPhase[]
  batchAssignments BatchCurriculumAssignment[]
}

model CurriculumPhase {
  id            String  @id @default(cuid())
  curriculumId  String
  phaseNumber   Int
  name          String
  durationWeeks Int     @default(4)
  description   String?

  curriculum Curriculum        @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  topics     CurriculumTopic[]

  @@unique([curriculumId, phaseNumber])
}

model CurriculumTopic {
  id              String   @id @default(cuid())
  phaseId         String
  sequence        Int
  name            String
  skillArea       String? // BATTING | BOWLING | FIELDING | FITNESS | MENTAL | KEEPING
  subSkill        String?
  description     String?
  suggestedDrills String[] @default([])

  phase       CurriculumPhase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  completions TopicCompletion[]

  @@unique([phaseId, sequence])
}

model BatchCurriculumAssignment {
  id           String   @id @default(cuid())
  batchId      String   @unique
  curriculumId String
  startDate    DateTime
  currentPhase Int      @default(1)
  currentTopic Int      @default(1)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  batch       Batch             @relation(fields: [batchId], references: [id])
  curriculum  Curriculum        @relation(fields: [curriculumId], references: [id])
  completions TopicCompletion[]
}

model TopicCompletion {
  id           String   @id @default(cuid())
  assignmentId String
  topicId      String
  coachId      String // CoachProfile.id
  completedAt  DateTime @default(now())
  coachNote    String?

  assignment BatchCurriculumAssignment @relation(fields: [assignmentId], references: [id])
  topic      CurriculumTopic           @relation(fields: [topicId], references: [id])

  @@unique([assignmentId, topicId])
}

// ============================================================
// SECTION 23 — COACH COMPENSATION & PAYROLL
// ============================================================

model CoachCompensation {
  id                    String           @id @default(cuid())
  academyId             String
  coachId               String // CoachProfile.id
  compensationType      CompensationType @default(FIXED_MONTHLY)
  fixedAmountPaise      Int? // for FIXED_MONTHLY, FIXED_PLUS_INCENTIVE
  perSessionAmountPaise Int? // for PER_SESSION
  perBatchAmountPaise   Int? // for PER_BATCH
  incentiveRules        Json? // flexible: { type, threshold, bonusPaise }
  revenueSharePercent   Int? // 0-100, for 1-on-1 revenue share
  payoutCycle           String           @default("MONTHLY") // MONTHLY | FORTNIGHTLY
  payoutDay             Int              @default(1) // day of month
  isActive              Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  academy Academy             @relation(fields: [academyId], references: [id])
  coach   CoachProfile        @relation(fields: [coachId], references: [id])
  payouts CoachPayoutRecord[]

  @@unique([academyId, coachId])
}

model CoachPayoutRecord {
  id                   String       @id @default(cuid())
  compensationId       String
  academyId            String
  coachId              String // CoachProfile.id
  periodStart          DateTime
  periodEnd            DateTime
  sessionsCount        Int          @default(0)
  batchesCount         Int          @default(0)
  attendanceCompliance Float        @default(0) // 0-100%
  baseAmountPaise      Int          @default(0)
  incentiveAmountPaise Int          @default(0)
  oneOnOneSharePaise   Int          @default(0)
  deductionPaise       Int          @default(0)
  totalAmountPaise     Int          @default(0)
  status               PayoutStatus @default(PENDING)
  paidAt               DateTime?
  paymentRef           String?
  notes                String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  compensation CoachCompensation @relation(fields: [compensationId], references: [id])
  academy      Academy           @relation(fields: [academyId], references: [id])
  coach        CoachProfile      @relation(fields: [coachId], references: [id])

  @@index([academyId, status])
  @@index([coachId, periodStart])
}

// ============================================================
// SECTION 24 — 1-ON-1 COACHING
// ============================================================

model OneOnOneProfile {
  id              String   @id @default(cuid())
  coachId         String   @unique // CoachProfile.id
  isEnabled       Boolean  @default(false)
  expertiseTags   String[] @default([])
  bio             String?
  // pricePerSession in paise: { mins60, mins90, mins120 }
  pricePerSession Json     @default("{}")
  locationTypes   String[] @default([]) // COACH_GROUND | STUDENT_GROUND | ONLINE
  maxPerWeek      Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  coach    CoachProfile      @relation(fields: [coachId], references: [id])
  slots    OneOnOneSlot[]
  bookings OneOnOneBooking[]
}

model OneOnOneSlot {
  id        String  @id @default(cuid())
  profileId String
  dayOfWeek Int // 0=Sunday, 1=Monday ... 6=Saturday
  startTime String // "HH:MM" 24h
  endTime   String
  isActive  Boolean @default(true)

  profile OneOnOneProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model OneOnOneBooking {
  id               String    @id @default(cuid())
  profileId        String
  coachId          String // CoachProfile.id
  playerProfileId  String
  academyId        String? // if booked via academy context
  requestedAt      DateTime  @default(now())
  sessionDate      DateTime
  startTime        String // "HH:MM"
  durationMins     Int // 60 | 90 | 120
  locationType     String // COACH_GROUND | STUDENT_GROUND | ONLINE
  locationDetails  String?
  priceAmountPaise Int
  platformFeePaise Int       @default(0)
  academyCutPaise  Int       @default(0)
  coachPayoutPaise Int
  status           String    @default("REQUESTED") // REQUESTED | ACCEPTED | REJECTED | COMPLETED | CANCELLED | NO_SHOW
  studentNote      String?
  coachNote        String?
  rejectReason     String?
  rating           Int?
  review           String?
  razorpayOrderId  String?
  paidAt           DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profile       OneOnOneProfile @relation(fields: [profileId], references: [id])
  coach         CoachProfile    @relation(fields: [coachId], references: [id])
  playerProfile PlayerProfile   @relation(fields: [playerProfileId], references: [id])

  @@index([coachId, sessionDate])
  @@index([playerProfileId, sessionDate])
}

// ============================================================
// SECTION 16 — EVENTS
// ============================================================

model Event {
  id              String    @id @default(cuid())
  createdByUserId String
  name            String
  eventType       String    @default("CUSTOM") // SIXER_KING | FASTEST_50 | CUSTOM
  description     String?
  venueName       String?
  city            String?
  scheduledAt     DateTime?
  status          String    @default("UPCOMING") // UPCOMING | LIVE | COMPLETED | CANCELLED
  isPublic        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  createdBy User @relation(fields: [createdByUserId], references: [id])

  @@index([createdByUserId])
  @@index([status])
}

// ============================================================
// SECTION 21 — STOREFRONT
// ============================================================

model StoreOwnerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  stores Store[]

  @@map("store_owner_profiles")
}

model DeliveryPartnerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  vehicleType  String? // BIKE, SCOOTER, CYCLE
  vehicleRegNo String?
  isActive     Boolean  @default(true)
  isAvailable  Boolean  @default(false)
  currentLat   Float?
  currentLng   Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs DeliveryJob[]

  @@map("delivery_partner_profiles")
}

model Store {
  id                String   @id @default(cuid())
  ownerId           String
  businessAccountId String?
  academyId         String? // Optional link to academy
  name              String
  description       String?
  logoUrl           String?
  address           String
  city              String
  state             String
  pincode           String
  latitude          Float?
  longitude         Float?
  isActive          Boolean  @default(true)
  isFeatured        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  owner           StoreOwnerProfile @relation(fields: [ownerId], references: [id])
  businessAccount BusinessAccount?  @relation(fields: [businessAccountId], references: [id], onDelete: SetNull)
  inventory       StoreInventory[]
  orders          StoreOrder[]

  @@index([businessAccountId])
  @@index([city, isActive])
  @@map("stores")
}

model ProductCategory {
  id           String   @id @default(cuid())
  parentId     String?
  name         String
  description  String?
  iconUrl      String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parentId, displayOrder])
  @@map("product_categories")
}

model Product {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  description String?
  brand       String?
  basePrice   Int? // Optional base price if consistent across stores
  imageUrl    String?
  tags        String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category ProductCategory  @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]

  @@index([categoryId, isActive])
  @@map("products")
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  name       String // e.g. "1kg", "Choco", "Small"
  sku        String?  @unique
  imageUrl   String?
  attributes Json? // e.g. { weight: "1kg", color: "Red" }
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product    Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory  StoreInventory[]
  orderItems StoreOrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model StoreInventory {
  id                 String   @id @default(cuid())
  storeId            String
  productVariantId   String
  quantity           Int      @default(0)
  pricePaise         Int // Local store price
  discountPricePaise Int?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  store          Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([storeId, productVariantId])
  @@index([storeId])
  @@map("store_inventory")
}

model StoreOrder {
  id                  String   @id @default(cuid())
  storeId             String
  userId              String
  status              String   @default("PENDING") // PENDING, PAID, PREPARING, READY, DISPATCHED, DELIVERED, CANCELLED
  totalAmountPaise    Int
  deliveryFeePaise    Int      @default(0)
  taxAmountPaise      Int      @default(0)
  discountAmountPaise Int      @default(0)
  finalAmountPaise    Int
  paymentId           String?  @unique
  deliveryAddress     String
  deliveryLat         Float?
  deliveryLng         Float?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  store    Store            @relation(fields: [storeId], references: [id])
  user     User             @relation(fields: [userId], references: [id])
  items    StoreOrderItem[]
  delivery DeliveryJob?
  invoice  StoreInvoice?

  @@index([storeId, status])
  @@index([userId, status])
  @@map("store_orders")
}

model StoreOrderItem {
  id               String   @id @default(cuid())
  orderId          String
  productVariantId String
  quantity         Int
  pricePaise       Int // Snapshot of price at time of order
  totalPricePaise  Int
  createdAt        DateTime @default(now())

  order          StoreOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@map("store_order_items")
}

model DeliveryJob {
  id                String    @id @default(cuid())
  orderId           String    @unique
  partnerId         String?
  userId            String? // Link to customer for easy tracking
  status            String    @default("PENDING") // PENDING, ASSIGNED, PICKED_UP, NEAR_CUSTOMER, DELIVERED, RETURNED
  assignedAt        DateTime?
  pickedUpAt        DateTime?
  deliveredAt       DateTime?
  estimatedDelivery DateTime?
  trackingUrl       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  order   StoreOrder              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  partner DeliveryPartnerProfile? @relation(fields: [partnerId], references: [id])
  user    User?                   @relation(fields: [userId], references: [id])

  @@index([partnerId, status])
  @@index([userId])
  @@map("delivery_jobs")
}

model StoreInvoice {
  id            String   @id @default(cuid())
  orderId       String   @unique
  invoiceNumber String   @unique
  invoiceUrl    String?
  issuedAt      DateTime @default(now())
  createdAt     DateTime @default(now())

  order StoreOrder @relation(fields: [orderId], references: [id])

  @@map("store_invoices")
}

// --- PERFORMANCE DOMAIN (APEX ELITE) ---

enum PerformanceDayType {
  TRAINING
  MATCH
  RECOVERY
}

enum PerformanceSessionType {
  NETS
  SKILL_WORK
  CONDITIONING
  GYM
  MATCH
  RECOVERY
}

enum PlanWeekday {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum PerformanceDayActivityType {
  NETS
  SKILL_WORK
  GYM
  CONDITIONING
  MATCH
  RECOVERY
  PROPER_DIET
}

enum PerformanceActivityDomain {
  BATTING
  BOWLING
  FIELDING
  FITNESS
  RECOVERY
  NUTRITION
  MATCH
}

model PerformancePlan {
  id                    String    @id @default(cuid())
  playerId              String    @unique
  name                  String
  isActive              Boolean   @default(true)
  sleepTargetHours      Float     @default(8.0)
  hydrationTargetLiters Float     @default(3.0)
  dailyCalorieTarget    Int?
  isAlignedWithAmbition Boolean   @default(true)
  lastSyncedAt          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  activities PerformancePlanActivity[]
  days       PerformancePlanDay[]
  player     PlayerProfile             @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("performance_plans")
}

model PerformancePlanActivity {
  id           String                 @id @default(cuid())
  planId       String
  category     PerformanceSessionType
  timesPerWeek Int

  plan PerformancePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, category])
  @@map("performance_plan_activities")
}

model PerformancePlanDay {
  id                    String      @id @default(cuid())
  planId                String
  weekday               PlanWeekday
  hasNets               Boolean     @default(false)
  hasSkillWork          Boolean     @default(false)
  hasGym                Boolean     @default(false)
  hasConditioning       Boolean     @default(false)
  hasMatch              Boolean     @default(false)
  hasRecovery           Boolean     @default(false)
  hasProperDiet         Boolean     @default(false)
  netsMinutes           Int         @default(0)
  drillsMinutes         Int         @default(0)
  fitnessMinutes        Int         @default(0)
  recoveryMinutes       Int         @default(0)
  sleepTargetHours      Float       @default(8.0)
  hydrationTargetLiters Float       @default(3.5)

  plan PerformancePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, weekday])
  @@index([planId, weekday])
  @@map("performance_plan_days")
}

enum PerformanceSource {
  MANUAL
  WEARABLE
  COACH
  SYSTEM
  MATCH_ENGINE
}

enum MatchSourceType {
  APP_MATCH
  MANUAL_MATCH
}

model PerformanceDrill {
  id            String                 @id @default(cuid())
  code          String                 @unique
  name          String
  sessionType   PerformanceSessionType
  primarySkill  String
  secondaryTags String[]               @default([])
  difficulty    Int                    @default(1)
  isActive      Boolean                @default(true)
  createdAt     DateTime               @default(now())

  sessionDrills PerformanceSessionDrill[]

  @@map("performance_drills")
}

model PerformanceMetricDefinition {
  id          String  @id @default(cuid())
  code        String  @unique
  label       String
  category    String
  description String?
  isActive    Boolean @default(true)

  sessionRatings PerformanceSessionRating[]

  @@map("performance_metric_definitions")
}

model PerformanceAreaDefinition {
  id          String  @id @default(cuid())
  code        String  @unique
  label       String
  category    String
  description String?

  @@map("performance_area_definitions")
}

model PerformanceDayLog {
  id          String             @id @default(cuid())
  playerId    String
  date        DateTime           @db.Date
  type        PerformanceDayType
  dayTakeaway String?            @db.Text
  note        String?            @db.Text

  // Plan vs Execution State
  isLocked       Boolean  @default(false)
  cheatDay       Boolean  @default(false)
  oneThingToday  String?  @db.Text
  tookProperDiet Boolean?
  skippedMeal    Boolean?
  whatDidWell    String?  @db.Text
  whatDidBadly   String?  @db.Text
  executionScore Float? // The calculated EE% (0-100)

  // Daily Targets (The "Plan")
  targetNetsMinutes     Int?   @default(0)
  targetDrillsMinutes   Int?   @default(0)
  targetGymMinutes      Int?   @default(0)
  targetRecoveryMinutes Int?   @default(0)
  targetSleep           Float? @default(8.0)
  targetHydration       Float? @default(3.5)

  // Actuals (The "Execution" - derived or stored)
  actualNetsMinutes     Int @default(0)
  actualDrillsMinutes   Int @default(0)
  actualFitnessMinutes  Int @default(0)
  actualRecoveryMinutes Int @default(0)

  // Shared Day State (Wellness/Vitals)
  sleepHours      Float?
  sleepQuality    Int? // 1-10
  hydrationLiters Float?
  soreness        Int? // 1-10
  fatigue         Int? // 1-10
  stress          Int? // 1-10
  motivation      Int? // 1-10
  mentalFreshness Int? // 1-10
  readinessRating Int? // 1-10

  // Body & Nutrition Actuals
  caloriesConsumed     Int?
  waistCircumferenceCm Float?
  neckCircumferenceCm  Float?
  hipCircumferenceCm   Float?
  bodyFatPercent       Float?

  source          PerformanceSource @default(MANUAL)
  confidenceScore Float             @default(1.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  player         PlayerProfile              @relation(fields: [playerId], references: [id], onDelete: Cascade)
  activities     PerformanceDayActivity[]
  sessions       PerformanceSession[]
  matchReview    PerformanceMatchReview?
  recoveryDetail PerformanceRecoveryDetail?

  @@unique([playerId, date])
  @@index([playerId, date])
  @@map("performance_day_logs")
}

model PerformanceDayActivity {
  id           String                     @id @default(cuid())
  dayLogId     String
  activityType PerformanceDayActivityType
  wasPlanned   Boolean                    @default(false)
  wasCompleted Boolean                    @default(false)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  dayLog  PerformanceDayLog              @relation(fields: [dayLogId], references: [id], onDelete: Cascade)
  details PerformanceDayActivityDetail[]

  @@unique([dayLogId, activityType])
  @@index([dayLogId, activityType])
  @@map("performance_day_activities")
}

model PerformanceDayActivityDetail {
  id               String                    @id @default(cuid())
  activityId       String
  domain           PerformanceActivityDomain
  primaryFocus     String?
  secondaryFocuses String[]                  @default([])
  whatLearned      String?                   @db.Text
  whatMissed       String?                   @db.Text
  notes            String?                   @db.Text
  metadata         Json?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  activity PerformanceDayActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("performance_day_activity_details")
}

model WeeklyPlanTemplate {
  id        String   @id @default(cuid())
  playerId  String
  name      String // e.g. "Normal Training Week"
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  days   WeeklyPlanDay[]
  player PlayerProfile   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@map("weekly_plan_templates")
}

model WeeklyPlanDay {
  id         String @id @default(cuid())
  templateId String
  dayOfWeek  Int // 0 (Sun) to 6 (Sat)

  // Targets for this specific day of the week
  targetNetsMinutes     Int?   @default(0)
  targetDrillsMinutes   Int?   @default(0)
  targetGymMinutes      Int?   @default(0)
  targetRecoveryMinutes Int?   @default(0)
  targetSleep           Float? @default(8.0)
  targetHydration       Float? @default(3.5)

  template WeeklyPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, dayOfWeek])
  @@map("weekly_plan_days")
}

model PerformanceSession {
  id        String                 @id @default(cuid())
  dayLogId  String
  type      PerformanceSessionType
  startTime DateTime?

  plannedDuration Int?
  actualDuration  Int?

  plannedIntensity Int?
  actualIntensity  Int?

  objective String? @db.Text
  takeaway  String? @db.Text

  source PerformanceSource @default(MANUAL)

  dayLog  PerformanceDayLog          @relation(fields: [dayLogId], references: [id], onDelete: Cascade)
  drills  PerformanceSessionDrill[]
  ratings PerformanceSessionRating[]

  @@index([dayLogId])
  @@map("performance_sessions")
}

model PerformanceSessionDrill {
  id        String @id @default(cuid())
  sessionId String
  drillId   String

  plannedReps Int?
  actualReps  Int?

  executionQuality Int? // 1-10

  session PerformanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  drill   PerformanceDrill   @relation(fields: [drillId], references: [id])

  @@index([sessionId])
  @@map("performance_session_drills")
}

model PerformanceSessionRating {
  id         String @id @default(cuid())
  sessionId  String
  metricCode String
  value      Int // 1-10

  session    PerformanceSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  definition PerformanceMetricDefinition @relation(fields: [metricCode], references: [code])

  @@index([sessionId])
  @@map("performance_session_ratings")
}

model PerformanceMatchReview {
  id          String          @id @default(cuid())
  dayLogId    String          @unique
  matchSource MatchSourceType

  // If APP_MATCH
  matchId String?

  // If MANUAL_MATCH
  manualMatchName String?
  manualRuns      Int?
  manualBalls     Int?
  manualWickets   Int?
  manualOvers     Float?
  manualResult    String?

  role              String?
  intentCodes       String[]
  successDefinition String?  @db.Text

  selfRating    Int? // 1-10
  tacticalPivot String? @db.Text
  turningPoint  String? @db.Text

  dayLog PerformanceDayLog @relation(fields: [dayLogId], references: [id], onDelete: Cascade)
  match  Match?            @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([dayLogId])
  @@index([matchId])
  @@map("performance_match_reviews")
}

model PerformanceRecoveryDetail {
  id       String @id @default(cuid())
  dayLogId String @unique

  primaryActivity String
  notes           String? @db.Text

  dayLog PerformanceDayLog @relation(fields: [dayLogId], references: [id], onDelete: Cascade)

  @@map("performance_recovery_details")
}

model PerformanceWeeklyReview {
  id            String   @id @default(cuid())
  playerId      String
  weekStartDate DateTime @db.Date

  systemInsights   Json?
  playerReflection String? @db.Text

  agreedWeaknesses String[]
  nextWeekFocus    String[]

  isConfirmed Boolean @default(false)

  createdAt DateTime @default(now())

  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, weekStartDate])
  @@index([playerId, weekStartDate])
  @@map("performance_weekly_reviews")
}

model PerformanceAmbition {
  id                  String   @id @default(cuid())
  playerId            String   @unique
  targetRole          String
  targetFormat        String
  styleIdentity       String
  targetLevel         String
  timeline            String
  focusAreas          String[]
  commitmentStatement String?  @db.Text

  // Health & Body Transformation
  gender                   String?
  targetWeight             Float?
  bodyTransformDirection   BodyTransformDirection?
  targetBodyFatPercent     Float?
  waistCircumferenceCm     Float?
  neckCircumferenceCm      Float?
  hipCircumferenceCm       Float?
  bodyFatPercent           Float?
  trainingDaysPerWeek      Int?
  fitnessFocuses           String[]                @default([])
  nutritionObjective       NutritionObjective?
  dailySleepHoursGoal      Float?
  dailyHydrationLitresGoal Float?
  morningWakeUpTime        String?
  habitsToQuit             String[]                @default([])
  disciplineGoals          String[]                @default([])

  // Computed Health Metrics (Stored)
  dailyCalorieTarget Int?
  bmi                Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("performance_ambitions")
}

// ============================================================
// SECTION — CONTENT LIBRARY (Drill / Fitness / Nutrition)
// ============================================================

enum LibraryStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

model DrillLibraryItem {
  id          String  @id @default(cuid())
  createdById String?
  updatedById String?
  name        String
  slug        String  @unique
  description String? @db.Text

  // Taxonomy
  category        String? // TECHNIQUE | FITNESS | MENTAL | MATCH_SIMULATION
  skillArea       String?
  subSkill        String?
  roleTags        String[] @default([])
  goalTags        String[] @default([])
  formatTags      String[] @default([])
  equipmentTags   String[] @default([])
  bodyAreaTags    String[] @default([])
  levelTags       String[] @default([])
  roleSpecificity String?
  recommendedFor  String[] @default([])

  // Volume & Load
  difficulty     String  @default("BEGINNER") // BEGINNER | INTERMEDIATE | ADVANCED | ELITE
  durationMins   Int?
  targetUnit     String? // BALLS | OVERS | MINUTES | REPS | SESSIONS
  targetValue    Float?
  sets           Int?
  repsPerSet     Int?
  restSeconds    Int?
  intensityLevel String? // LOW | MODERATE | HIGH | MAXIMAL
  recoveryLoad   String? // LOW | MODERATE | HIGH
  fatigueImpact  String? // LOW | MODERATE | HIGH

  // Constraints
  handedness String? // BOTH | RIGHT | LEFT
  minAge     Int?
  maxAge     Int?

  // Instructions
  instructions    Json?
  coachingCues    String[] @default([])
  commonMistakes  String[] @default([])
  successCriteria String[] @default([])
  contraNotes     String[] @default([])

  // Media
  videoUrl     String?
  thumbnailUrl String?

  // Source
  sourceType String? @default("SWING") // SWING | COACH | EXTERNAL
  sourceRef  String?

  // Metadata
  status      LibraryStatus @default(DRAFT)
  isPublic    Boolean       @default(false)
  isActive    Boolean       @default(true)
  sortOrder   Int           @default(0)
  usageCount  Int           @default(0)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, category])
  @@index([slug])
  @@map("drill_library_items")
}

model FitnessExercise {
  id          String  @id @default(cuid())
  createdById String?
  updatedById String?
  name        String
  slug        String  @unique
  description String? @db.Text

  // Taxonomy
  category       String?
  subCategory    String?
  goalTags       String[] @default([])
  bodyAreaTags   String[] @default([])
  roleTags       String[] @default([])
  levelTags      String[] @default([])
  formatTags     String[] @default([])
  equipmentTags  String[] @default([])
  recommendedFor String[] @default([])
  avoidIfTags    String[] @default([])

  // Volume
  durationMins    Int?
  sets            Int?
  reps            Int?
  repsPerSide     Int?
  holdSeconds     Int?
  restSeconds     Int?
  coolDownSeconds Int?
  targetUnit      String?
  targetValue     Float?

  // Load
  intensityLevel String?
  readinessMin   Int?
  readinessMax   Int?
  fatigueImpact  String?
  recoveryLoad   String?

  // Instructions
  instructions     Json?
  coachingCues     String[] @default([])
  commonMistakes   String[] @default([])
  contraNotes      String[] @default([])
  progressionNotes String?  @db.Text
  regressionNotes  String?  @db.Text

  // Media
  videoUrl     String?
  thumbnailUrl String?

  // Metadata
  status      LibraryStatus @default(DRAFT)
  isPublic    Boolean       @default(false)
  isActive    Boolean       @default(true)
  sortOrder   Int           @default(0)
  usageCount  Int           @default(0)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, category])
  @@index([slug])
  @@map("fitness_exercises")
}

model NutritionItem {
  id          String  @id @default(cuid())
  createdById String?
  updatedById String?
  name        String
  slug        String  @unique
  description String? @db.Text

  // Taxonomy
  category       String?
  subCategory    String?
  goalTags       String[] @default([])
  timingTags     String[] @default([])
  dietTags       String[] @default([])
  allergenTags   String[] @default([])
  cuisineTags    String[] @default([])
  recommendedFor String[] @default([])
  avoidIfTags    String[] @default([])

  // Serving
  servingQty           Float?
  servingUnit          String?
  frequencyNote        String?
  prepTimeMins         Int?
  bestWindowMinsBefore Int?
  bestWindowMinsAfter  Int?

  // Macros
  calories    Float?
  proteinG    Float?
  carbsG      Float?
  fatG        Float?
  fiberG      Float?
  sugarG      Float?
  sodiumMg    Float?
  potassiumMg Float?
  waterMl     Float?

  // Scores
  hydrationScore Float?
  recoveryScore  Float?
  energyScore    Float?
  digestibility  String? // LIGHT | MODERATE | HEAVY

  // Flags
  matchDaySafe     Boolean @default(false)
  heavyMeal        Boolean @default(false)
  suitabilityNotes String?

  // Metadata
  status      LibraryStatus @default(DRAFT)
  isPublic    Boolean       @default(false)
  isActive    Boolean       @default(true)
  sortOrder   Int           @default(0)
  usageCount  Int           @default(0)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  recipes NutritionRecipe[]

  @@index([status, category])
  @@index([slug])
  @@map("nutrition_items")
}

model NutritionRecipe {
  id              String        @id @default(cuid())
  nutritionItemId String
  title           String
  description     String?       @db.Text
  ingredients     Json?
  instructions    Json?
  prepTimeMins    Int?
  cookTimeMins    Int?
  totalTimeMins   Int?
  serves          Int?
  videoUrl        String?
  thumbnailUrl    String?
  isPrimary       Boolean       @default(false)
  status          LibraryStatus @default(DRAFT)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  nutritionItem NutritionItem @relation(fields: [nutritionItemId], references: [id], onDelete: Cascade)

  @@index([nutritionItemId])
  @@map("nutrition_recipes")
}
