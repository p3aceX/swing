model Drill {
  id           String          @id @default(cuid())
  createdById  String?
  name         String
  description  String?
  skillArea    String
  subSkill     String?
  difficulty   DrillDifficulty @default(BEGINNER)
  durationMins Int             @default(20)
  videoUrl     String?
  thumbnailUrl String?
  tags         String[]
  roleTags     RoleTag[]
