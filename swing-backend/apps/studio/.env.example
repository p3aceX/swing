# Studio Service Configuration
STUDIO_PORT=4000
RTMP_PORT=1935
RTMP_HTTP_PORT=8888

# Public hostname (used in RTMP URLs sent to phones)
PUBLIC_HOST=studio.swingcricket.com

# Swing API (for overlay widget capture)
API_BASE_URL=https://api.swingcricket.com

# Redis (same as main API)
REDIS_URL=redis://localhost:6379

# FFmpeg path (default: ffmpeg)
FFMPEG_PATH=ffmpeg
